<Window x:Class="FFXIVTataruHelper.OutgoingChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:utils="clr-namespace:WpfXamlExtensions;assembly=WpfXamlExtensions"
        mc:Ignorable="d"
        AllowsTransparency="True"
        WindowStyle="None"
        Title="{DynamicResource OutgoingChatWindowTitle}"
        Top="{Binding WindowTop, Mode=TwoWay}"
        Left="{Binding WindowLeft, Mode=TwoWay}"
        Width="{Binding WindowWidth, Mode=TwoWay}"
        Height="{Binding WindowHeight, Mode=TwoWay}"
        MinWidth="320" MinHeight="90"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid x:Name="RootGrid">
        <Border x:Name="WindowSurface"
                Background="{Binding BackgroundColor, Converter={utils:ColorToSolidColorBrush}, Mode=OneWay}"
                Opacity="{Binding WindowOpacity, Mode=OneWay}"
                CornerRadius="6"
                BorderBrush="#40FFFFFF"
                BorderThickness="1" />

        <Border x:Name="HoverChrome"
                Margin="1"
                CornerRadius="6"
                BorderBrush="{DynamicResource Brush.Accent}"
                BorderThickness="1"
                Opacity="0"
                IsHitTestVisible="False">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="0" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=RootGrid}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="0.85" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <Grid Margin="10,12,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{DynamicResource OutgoingChatChannelLabel}"
                           Foreground="White"
                           VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox Grid.Column="1"
                          MinWidth="160"
                          HorizontalAlignment="Left"
                          ItemsSource="{Binding Channels}"
                          SelectedItem="{Binding SelectedChannel, Mode=TwoWay}" />
                <TextBlock Grid.Column="2"
                           Foreground="#CCFFFFFF"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Text="{Binding Utf8ByteLength, StringFormat={}{0} B}" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,6"
                  Visibility="{Binding IsTellSelected, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{DynamicResource OutgoingChatTellTargetLabel}"
                           Foreground="White"
                           VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox Grid.Column="1"
                          IsEditable="True"
                          Text="{Binding TellTarget, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding RecentTells}" />
            </Grid>

            <TextBox x:Name="MessageTextBox"
                     Grid.Row="2"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Background="#40000000"
                     Foreground="White"
                     CaretBrush="White"
                     BorderBrush="#60FFFFFF"
                     BorderThickness="1"
                     Padding="6"
                     Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}" />

            <DockPanel Grid.Row="3" Margin="0,6,0,0" LastChildFill="False">
                <TextBlock Text="{Binding StatusMessage}"
                           DockPanel.Dock="Left"
                           Foreground="#CCFFFFFF"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="280" />
                <Button Content="{DynamicResource OutgoingChatCopyButton}"
                        Command="{Binding CopyCommand}"
                        DockPanel.Dock="Right" MinWidth="100" Margin="6,0,0,0" />
            </DockPanel>
        </Grid>

        <!-- Resize handles -->
        <Rectangle x:Name="top" Opacity="0.0" Fill="#00000000" Height="14" Margin="0" VerticalAlignment="Top"
                   MouseEnter="DisplayDragCursor" MouseLeave="ResetCursor" PreviewMouseDown="Drag" />
        <Rectangle x:Name="left" Opacity="0.0" Fill="#00000000" HorizontalAlignment="Left" Margin="0" Width="6"
                   MouseEnter="DisplayResizeCursor" MouseLeave="ResetCursor" PreviewMouseDown="Resize" />
        <Rectangle x:Name="right" Opacity="0.0" Fill="#00000000" HorizontalAlignment="Right" Margin="0" Width="6"
                   MouseEnter="DisplayResizeCursor" MouseLeave="ResetCursor" PreviewMouseDown="Resize" />
        <Rectangle x:Name="bottom" Opacity="0.0" Fill="#00000000" Height="6" Margin="0" VerticalAlignment="Bottom"
                   MouseEnter="DisplayResizeCursor" MouseLeave="ResetCursor" PreviewMouseDown="Resize" />
        <Rectangle x:Name="topLeft" Opacity="0.0" Fill="#00000000" HorizontalAlignment="Left" Height="10" Margin="0"
                   VerticalAlignment="Top" Width="10" MouseEnter="DisplayResizeCursor" MouseLeave="ResetCursor"
                   PreviewMouseDown="Resize" />
        <Rectangle x:Name="topRight" Opacity="0.0" Fill="#00000000" HorizontalAlignment="Right" Height="10" Margin="0"
                   VerticalAlignment="Top" Width="10" MouseEnter="DisplayResizeCursor" MouseLeave="ResetCursor"
                   PreviewMouseDown="Resize" />
        <Rectangle x:Name="bottomRight" Opacity="0.0" Fill="#00000000" HorizontalAlignment="Right" Height="10"
                   Margin="0" VerticalAlignment="Bottom" Width="10" MouseEnter="DisplayResizeCursor"
                   MouseLeave="ResetCursor" PreviewMouseDown="Resize" />
        <Rectangle x:Name="bottomLeft" Opacity="0.0" Fill="#00000000" HorizontalAlignment="Left" Height="10" Margin="0"
                   VerticalAlignment="Bottom" Width="10" MouseEnter="DisplayResizeCursor" MouseLeave="ResetCursor"
                   PreviewMouseDown="Resize" />

        <!-- Drag handle chip -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,4,0,0"
                Padding="6,2"
                CornerRadius="10"
                Background="#A0202020"
                BorderBrush="#40FFFFFF"
                BorderThickness="1"
                IsHitTestVisible="False">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="0" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=RootGrid}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <ui:SymbolIcon Symbol="ReOrderDotsHorizontal24" FontSize="12" Foreground="#FFFFFFFF" />
        </Border>

        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="{DynamicResource SettingsHide}" Click="HideThisWindow_Click">
                    <MenuItem.Icon>
                        <ui:SymbolIcon Symbol="EyeOff24" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{DynamicResource SettingsWindowName}" Click="Settings_Click">
                    <MenuItem.Icon>
                        <ui:SymbolIcon Symbol="Settings24" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="{DynamicResource SettingsExit}" Click="Exit_Click">
                    <MenuItem.Icon>
                        <ui:SymbolIcon Symbol="SignOut24" />
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </Grid.ContextMenu>
    </Grid>
</Window>