<UserControl x:Class="FFXIVTataruHelper.Controls.FluentColorEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             x:Name="Root"
             mc:Ignorable="d"
             Width="276"
             Background="Transparent">
    <UserControl.Resources>
        <DrawingBrush x:Key="CheckerBrush" TileMode="Tile" Viewport="0,0,8,8" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#FFE5E5E5">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,8,8" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FFB8B8B8">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,4,4" />
                                <RectangleGeometry Rect="4,4,4,4" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </UserControl.Resources>

    <StackPanel>
        <!-- SV (saturation/value) plane -->
        <Border CornerRadius="6"
                ClipToBounds="True"
                Height="156"
                Margin="0,0,0,10"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1">
            <Grid x:Name="SvBox"
                  Background="Transparent"
                  MouseLeftButtonDown="SvBox_OnMouseDown"
                  MouseMove="SvBox_OnMouseMove"
                  MouseLeftButtonUp="SvBox_OnMouseUp">
                <Rectangle x:Name="HueLayer" />
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Offset="0" Color="#FFFFFFFF" />
                            <GradientStop Offset="1" Color="#00FFFFFF" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Offset="0" Color="#00000000" />
                            <GradientStop Offset="1" Color="#FF000000" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Canvas IsHitTestVisible="False">
                    <Border x:Name="SvCursor"
                            Width="14" Height="14"
                            CornerRadius="7"
                            BorderBrush="White"
                            BorderThickness="2"
                            Background="Transparent">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.6" Color="Black" />
                        </Border.Effect>
                    </Border>
                </Canvas>
            </Grid>
        </Border>

        <!-- Hue track -->
        <Border CornerRadius="5"
                ClipToBounds="True"
                Height="14"
                Margin="0,0,0,8"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1">
            <Grid x:Name="HueBar"
                  Background="Transparent"
                  MouseLeftButtonDown="HueBar_OnMouseDown"
                  MouseMove="HueBar_OnMouseMove"
                  MouseLeftButtonUp="HueBar_OnMouseUp">
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Offset="0" Color="#FFFF0000" />
                            <GradientStop Offset="0.1667" Color="#FFFFFF00" />
                            <GradientStop Offset="0.3333" Color="#FF00FF00" />
                            <GradientStop Offset="0.5" Color="#FF00FFFF" />
                            <GradientStop Offset="0.6667" Color="#FF0000FF" />
                            <GradientStop Offset="0.8333" Color="#FFFF00FF" />
                            <GradientStop Offset="1" Color="#FFFF0000" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Canvas IsHitTestVisible="False">
                    <Border x:Name="HueCursor"
                            Width="8" Height="14"
                            Background="Transparent"
                            BorderBrush="White"
                            BorderThickness="2"
                            CornerRadius="3">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.6" Color="Black" />
                        </Border.Effect>
                    </Border>
                </Canvas>
            </Grid>
        </Border>

        <!-- Alpha track -->
        <Border CornerRadius="5"
                ClipToBounds="True"
                Height="14"
                Margin="0,0,0,12"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1">
            <Grid x:Name="AlphaBar"
                  Background="Transparent"
                  MouseLeftButtonDown="AlphaBar_OnMouseDown"
                  MouseMove="AlphaBar_OnMouseMove"
                  MouseLeftButtonUp="AlphaBar_OnMouseUp">
                <Rectangle Fill="{StaticResource CheckerBrush}" />
                <Rectangle x:Name="AlphaGradient" />
                <Canvas IsHitTestVisible="False">
                    <Border x:Name="AlphaCursor"
                            Width="8" Height="14"
                            Background="Transparent"
                            BorderBrush="White"
                            BorderThickness="2"
                            CornerRadius="3">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.6" Color="Black" />
                        </Border.Effect>
                    </Border>
                </Canvas>
            </Grid>
        </Border>

        <!-- Preview + Hex -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Height="32"
                    Margin="0,0,8,0"
                    CornerRadius="6"
                    ClipToBounds="True"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1">
                <Grid>
                    <Rectangle Fill="{StaticResource CheckerBrush}" />
                    <Rectangle x:Name="PreviewSwatch" />
                </Grid>
            </Border>
            <ui:TextBox Grid.Column="1"
                        x:Name="HexBox"
                        VerticalAlignment="Center"
                        FontFamily="Consolas"
                        MaxLength="9"
                        LostFocus="HexBox_OnLostFocus"
                        KeyDown="HexBox_OnKeyDown" />
        </Grid>

        <!-- RGBA -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                <TextBlock Text="R" HorizontalAlignment="Center"
                           Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11" />
                <ui:NumberBox x:Name="RBox" Minimum="0" Maximum="255"
                              ClearButtonEnabled="False"
                              SpinButtonPlacementMode="Hidden"
                              ValueChanged="ChannelBox_OnValueChanged" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="2,0,2,0">
                <TextBlock Text="G" HorizontalAlignment="Center"
                           Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11" />
                <ui:NumberBox x:Name="GBox" Minimum="0" Maximum="255"
                              ClearButtonEnabled="False"
                              SpinButtonPlacementMode="Hidden"
                              ValueChanged="ChannelBox_OnValueChanged" />
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="2,0,2,0">
                <TextBlock Text="B" HorizontalAlignment="Center"
                           Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11" />
                <ui:NumberBox x:Name="BBox" Minimum="0" Maximum="255"
                              ClearButtonEnabled="False"
                              SpinButtonPlacementMode="Hidden"
                              ValueChanged="ChannelBox_OnValueChanged" />
            </StackPanel>
            <StackPanel Grid.Column="3" Margin="4,0,0,0">
                <TextBlock Text="A" HorizontalAlignment="Center"
                           Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11" />
                <ui:NumberBox x:Name="ABox" Minimum="0" Maximum="255"
                              ClearButtonEnabled="False"
                              SpinButtonPlacementMode="Hidden"
                              ValueChanged="ChannelBox_OnValueChanged" />
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>