<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <FontFamily x:Key="Font.Ui">Segoe UI Variable Text, Segoe UI</FontFamily>
    <sys:Double x:Key="FontSize.Caption">11</sys:Double>
    <sys:Double x:Key="FontSize.Body">12</sys:Double>
    <sys:Double x:Key="FontSize.Subtitle">14</sys:Double>
    <sys:Double x:Key="FontSize.Title">18</sys:Double>

</ResourceDictionary>