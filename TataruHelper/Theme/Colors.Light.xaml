<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Color.Background">#FFF3F3F3</Color>
    <Color x:Key="Color.Surface">#FFFBFBFB</Color>
    <Color x:Key="Color.SurfaceSubtle">#FFF6F6F6</Color>
    <Color x:Key="Color.Border">#15000000</Color>
    <Color x:Key="Color.BorderStrong">#26000000</Color>
    <Color x:Key="Color.TextPrimary">#E4000000</Color>
    <Color x:Key="Color.TextSecondary">#9B000000</Color>
    <Color x:Key="Color.Accent">#FF0067C0</Color>
    <Color x:Key="Color.AccentMuted">#FFCCE4F7</Color>
    <Color x:Key="Color.AccentHover">#FF0058A8</Color>
    <Color x:Key="Color.AccentPressed">#FF004B8E</Color>
    <Color x:Key="Color.Success">#FF1F7A4F</Color>
    <Color x:Key="Color.Warning">#FFB07411</Color>
    <Color x:Key="Color.Danger">#FFB53D44</Color>

    <SolidColorBrush x:Key="Brush.Background" Color="{StaticResource Color.Background}" />
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}" />
    <SolidColorBrush x:Key="Brush.SurfaceSubtle" Color="{StaticResource Color.SurfaceSubtle}" />
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="{StaticResource Color.BorderStrong}" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.AccentMuted" Color="{StaticResource Color.AccentMuted}" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="{StaticResource Color.AccentHover}" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="{StaticResource Color.AccentPressed}" />
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}" />
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}" />

</ResourceDictionary>