<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tb="http://www.hardcodet.net/taskbar"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:WpfXamlExtensions;assembly=WpfXamlExtensions"
    x:Class="FFXIVTataruHelper.MainWindow"
    mc:Ignorable="d"
    Icon="Resources/tray_icon.ico"
    MinHeight="700"
    MinWidth="1100"
    MaxWidth="2560"
    MaxHeight="1440"
    x:Name="TataruSettingsWindow"
    Title="{DynamicResource SettingsWindowName}" Height="820" Width="1280" ResizeMode="CanResize"
    Background="{DynamicResource Brush.Background}"
    Foreground="{DynamicResource Brush.TextPrimary}"
    FontFamily="{DynamicResource Font.Ui}"
    FontSize="{DynamicResource FontSize.Body}"
    Closing="Window_Closing" Closed="Window_Closed" Loaded="Window_Loaded" SizeChanged="Window_SizeChanged">

    <Grid Background="{DynamicResource Brush.Background}">
        <tb:TaskbarIcon x:Name="TaskBarIcon" IconSource="Resources/tray_icon.ico" TrayMouseDoubleClick="TBDoubleClick"
                        ToolTipText="Tataru Helper">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu DataContext="{Binding ElementName=TataruSettingsWindow, Path=DataContext}">
                    <MenuItem Header="{DynamicResource ChatWindowsTab}" IsEnabled="False" />
                    <ItemsControl ItemsSource="{Binding SettingsViewModel.ChatWindows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <MenuItem Header="{Binding Name}" Command="{Binding ShowChatWindowCommand}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Separator />
                    <MenuItem Header="{DynamicResource SettingsExit}" Click="TBMenuExit_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{DynamicResource CardBorderStyle}" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{DynamicResource SettingsWindowName}"
                               FontSize="{DynamicResource FontSize.Title}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,8,0" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource DocLanguage}" Margin="0,0,8,0" />
                        <ComboBox Width="210"
                                  Style="{DynamicResource BaseComboBoxStyle}"
                                  Margin="0"
                                  ItemsSource="{Binding Languages}"
                                  SelectedItem="{Binding SelectedLanguageOption, Mode=TwoWay}"
                                  DisplayMemberPath="Title" />
                    </StackPanel>

                    <Button Grid.Column="2" x:Name="CheckUpdatesButton"
                            Style="{DynamicResource AccentButtonStyle}"
                            Content="{DynamicResource CheckUpdatesText}"
                            Command="{Binding CheckUpdatesCommand}" />

                    <Border Grid.Column="3"
                            Background="{DynamicResource Brush.SurfaceSubtle}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,6"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource FFStatusLable}" Margin="0,0,6,0" />
                            <TextBlock x:Name="FFStatusText" Text="{Binding FfStatusText}" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,8,0,10"
                    Padding="10,8"
                    Background="{DynamicResource Brush.AccentMuted}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="{Binding SettingsViewModel.UpdatingBlockVisibility, Converter={utils:BooleanToVisibilityConverterCollapse}, Mode=OneWay}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="UserStartedUpdateText"
                               Visibility="{Binding SettingsViewModel.UserStartedUpdateTextVisibility, Converter={utils:BooleanToVisibilityConverterCollapse}, Mode=OneWay}" />
                    <TextBlock Margin="10,0,0,0"
                               Text="{DynamicResource DownloadingUpdate}"
                               Visibility="{Binding SettingsViewModel.DownloadingUpdateVisibility, Converter={utils:BooleanToVisibilityConverterCollapse}, Mode=OneWay}" />
                    <TextBlock Margin="10,0,0,0"
                               Text="{DynamicResource UpdateInstalled}"
                               Cursor="Hand"
                               FontWeight="SemiBold"
                               TextDecorations="Underline"
                               Visibility="{Binding SettingsViewModel.RestartReadyVisibility, Converter={utils:BooleanToVisibilityConverterCollapse}, Mode=OneWay}"
                               PreviewMouseDown="RestartApp_Click" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="310" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{DynamicResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="{DynamicResource ChatWindowsTab}"
                                   FontSize="{DynamicResource FontSize.Subtitle}"
                                   FontWeight="SemiBold" />

                        <ComboBox Grid.Row="1"
                                  Margin="0,8,0,6"
                                  Style="{DynamicResource BaseComboBoxStyle}"
                                  ItemsSource="{Binding SettingsViewModel.ChatWindows}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="WinId"
                                  SelectedValue="{Binding SelectedChatWindowId, Mode=TwoWay}" />

                        <UniformGrid Grid.Row="2" Columns="2" Margin="0,0,0,8">
                            <Button Style="{DynamicResource SidebarActionButtonStyle}"
                                    Content="{DynamicResource AddButtonText}"
                                    Command="{Binding AddWindowCommand}" />
                            <Button Style="{DynamicResource SidebarActionButtonStyle}"
                                    Content="{DynamicResource DeleteButtonText}"
                                    Command="{Binding DeleteWindowCommand}" />
                            <Button Style="{DynamicResource SidebarActionButtonStyle}"
                                    Content="{DynamicResource ShowHideButtonText}"
                                    Command="{Binding ShowHideWindowCommand}" />
                            <Button Style="{DynamicResource SidebarActionButtonStyle}"
                                    Content="{DynamicResource ResetButtonText}"
                                    Command="{Binding ResetPositionCommand}" />
                        </UniformGrid>

                        <Separator Grid.Row="3" Margin="0,0,0,8" Background="{DynamicResource Brush.Border}" Height="1" />

                        <ListBox Grid.Row="4"
                                 Style="{DynamicResource SidebarSectionListStyle}"
                                 ItemContainerStyle="{DynamicResource SidebarSectionItemStyle}"
                                 ItemsSource="{Binding Sections}"
                                 SelectedItem="{Binding SelectedSection, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{DynamicResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource Brush.Surface}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{DynamicResource ActiveChatWindowLabel}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,10,0" />

                                <TextBlock Grid.Column="1"
                                           Text="{Binding CurrentChatWindow.Name}"
                                           Margin="0,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.TextSecondary}" />

                            </Grid>
                        </Border>

                        <ContentControl x:Name="SectionContentHost" Grid.Row="1" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>