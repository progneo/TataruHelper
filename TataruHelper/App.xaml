<Application x:Class="FFXIVTataruHelper.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Wpf.Ui theme + controls -->
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />

                <!-- Localized strings -->
                <ResourceDictionary x:Name="TextDict" Source="TextDictionary.xaml" />

                <!-- App theme tokens (loaded once; AppThemeService swaps Colors at runtime) -->
                <ResourceDictionary Source="Theme/Colors.xaml" />
                <ResourceDictionary Source="Theme/Typography.xaml" />
                <ResourceDictionary Source="Theme/Spacing.xaml" />
                <ResourceDictionary Source="Theme/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>