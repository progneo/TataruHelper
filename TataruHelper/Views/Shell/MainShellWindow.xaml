<Window x:Class="FFXIVTataruHelper.Views.Shell.MainShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tataru Helper"
        Width="980"
        Height="640"
        MinWidth="840"
        MinHeight="520"
        Background="{DynamicResource Brush.Background}"
        FontFamily="{DynamicResource Font.Ui}"
        FontSize="{DynamicResource FontSize.Body}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,1,0"
                Padding="16">
            <StackPanel>
                <TextBlock Text="Settings"
                           Style="{DynamicResource BaseTextBlockStyle}"
                           FontSize="{DynamicResource FontSize.Title}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,16" />
                <ListBox ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Padding="20"
                Background="{DynamicResource Brush.Background}">
            <ContentControl Content="{Binding CurrentPageView}" />
        </Border>
    </Grid>
</Window>