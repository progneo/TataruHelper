<Window x:Class="FFXIVTataruHelper.Views.Shell.MainShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:pages="clr-namespace:FFXIVTataruHelper.Views.Pages"
        mc:Ignorable="d"
        Title="Modern Settings Preview"
        Width="1100"
        Height="740"
        MinWidth="900"
        MinHeight="620"
        Background="{DynamicResource Brush.Background}"
        FontFamily="{DynamicResource Font.Ui}"
        FontSize="{DynamicResource FontSize.Body}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                Padding="12"
                Margin="0,0,0,12">
            <TextBlock Text="Settings (Modern Preview)"
                       Style="{DynamicResource BaseTextBlockStyle}"
                       FontSize="{DynamicResource FontSize.Title}"
                       FontWeight="SemiBold" />
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                Padding="12">
            <TabControl>
                <TabItem Header="General">
                    <pages:GeneralPage />
                </TabItem>
                <TabItem Header="Chat Windows">
                    <pages:ChatWindowsPage />
                </TabItem>
                <TabItem Header="Translation">
                    <pages:TranslationPage />
                </TabItem>
                <TabItem Header="Appearance">
                    <pages:AppearancePage />
                </TabItem>
                <TabItem Header="Hotkeys">
                    <pages:HotkeysPage />
                </TabItem>
                <TabItem Header="About">
                    <pages:AboutPage />
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>