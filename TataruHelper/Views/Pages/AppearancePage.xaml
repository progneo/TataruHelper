<UserControl x:Class="FFXIVTataruHelper.Views.Pages.AppearancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="{DynamicResource SectionAppearance}"
                           Style="{DynamicResource BaseTextBlockStyle}"
                           FontSize="{DynamicResource FontSize.Subtitle}"
                           FontWeight="SemiBold" />
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{DynamicResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource TypographyLabel}" FontWeight="SemiBold" Margin="0,0,0,8" />

                        <Label Style="{DynamicResource BaseLabelStyle}" Content="{DynamicResource FontSize}" />
                        <xctk:IntegerUpDown Style="{DynamicResource BaseNumericUpDownStyle}"
                                            Value="{Binding BoundWindow.ChatFontSize, Mode=TwoWay}" Minimum="1"
                                            Maximum="100" Margin="0,0,0,8" />

                        <Label Style="{DynamicResource BaseLabelStyle}" Content="{DynamicResource FontFamily}" />
                        <ComboBox Style="{DynamicResource BaseComboBoxStyle}"
                                  ItemsSource="{Binding Source={x:Static Fonts.SystemFontFamilies}}"
                                  SelectedItem="{Binding BoundWindow.ChatFont, Mode=TwoWay}" />

                        <CheckBox Style="{DynamicResource BaseCheckBoxStyle}"
                                  IsChecked="{Binding BoundWindow.ShowTimestamps, Mode=TwoWay}"
                                  Content="{DynamicResource ShowTimestampsCb}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{DynamicResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource WindowSurfaceLabel}" FontWeight="SemiBold" Margin="0,0,0,8" />

                        <Label Style="{DynamicResource BaseLabelStyle}" Content="{DynamicResource BackgroundColor}" />
                        <xctk:ColorPicker Style="{DynamicResource BaseColorPickerStyle}"
                                          SelectedColor="{Binding BoundWindow.BackGroundColor, Mode=TwoWay}"
                                          ShowAvailableColors="False"
                                          ShowStandardColors="True"
                                          ShowRecentColors="True"
                                          Margin="0,0,0,8" />

                        <Label Style="{DynamicResource BaseLabelStyle}" Content="{DynamicResource IntervalWidth}" />
                        <xctk:IntegerUpDown Value="{Binding BoundWindow.SpacingCount, Mode=TwoWay}" Minimum="0"
                                            Maximum="100" Margin="0,0,0,8" />

                        <Label Style="{DynamicResource BaseLabelStyle}" Content="{DynamicResource LineBreakHeight}" />
                        <xctk:IntegerUpDown Style="{DynamicResource BaseNumericUpDownStyle}"
                                            Value="{Binding BoundWindow.LineBreakHeight, Mode=TwoWay}" Minimum="0"
                                            Maximum="100" Margin="0,0,0,8" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>