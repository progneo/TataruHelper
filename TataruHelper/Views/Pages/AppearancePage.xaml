<UserControl x:Class="FFXIVTataruHelper.Views.Pages.AppearancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ctrl="clr-namespace:FFXIVTataruHelper.Controls"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Style="{DynamicResource SectionTitleStyle}"
                       Text="{DynamicResource SectionAppearance}" />

            <TextBlock Grid.Row="1"
                       Style="{DynamicResource CaptionTextStyle}"
                       Margin="0,0,0,16"
                       Text="{DynamicResource AppearancePageDescription}" />

            <Grid Grid.Row="2" VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Top">
                    <ui:Card Padding="16" Margin="0,0,0,12" VerticalAlignment="Top">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <ui:SymbolIcon Symbol="TextFont24" FontSize="16"
                                                   Margin="0,0,8,0" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Brush.Accent}" />
                                    <TextBlock Style="{DynamicResource SectionSubtitleStyle}"
                                               Margin="0"
                                               Text="{DynamicResource TypographyLabel}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Style="{DynamicResource CaptionTextStyle}"
                                           Text="Choose text style and readability defaults for this overlay window." />
                            </StackPanel>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource FontFamily}" />
                            <ComboBox Grid.Row="1" Grid.Column="1"
                                      ItemsSource="{Binding Source={x:Static Fonts.SystemFontFamilies}}"
                                      SelectedItem="{Binding BoundWindow.ChatFont, Mode=TwoWay}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" Text="{DynamicResource FontSize}" />
                            <ui:NumberBox Grid.Row="2" Grid.Column="1"
                                          Margin="0,10,0,0"
                                          Value="{Binding BoundWindow.ChatFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Minimum="1" Maximum="100"
                                          ClearButtonEnabled="False" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,0"
                                       Text="{DynamicResource ShowTimestampsCb}" />
                            <ui:ToggleSwitch Grid.Row="3" Grid.Column="1"
                                             Margin="0,10,0,0"
                                             IsChecked="{Binding BoundWindow.ShowTimestamps, Mode=TwoWay}" />
                        </Grid>
                    </ui:Card>

                    <ui:Card Padding="16" VerticalAlignment="Top">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <ui:SymbolIcon Symbol="WindowApps24" FontSize="16"
                                                   Margin="0,0,8,0" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Brush.Accent}" />
                                    <TextBlock Style="{DynamicResource SectionSubtitleStyle}"
                                               Margin="0"
                                               Text="{DynamicResource OverlayBehaviorLabel}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Style="{DynamicResource CaptionTextStyle}"
                                           Text="Configure how the chat overlay behaves in game." />
                            </StackPanel>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource AlwaysOnTopCB}" />
                            <ui:ToggleSwitch Grid.Row="1" Grid.Column="1"
                                             HorizontalAlignment="Right"
                                             IsChecked="{Binding BoundWindow.IsAlwaysOnTop, Mode=TwoWay}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0"
                                       Text="{DynamicResource ClickThroughCB}" />
                            <ui:ToggleSwitch Grid.Row="2" Grid.Column="1"
                                             Margin="0,10,0,0"
                                             HorizontalAlignment="Right"
                                             IsChecked="{Binding BoundWindow.IsClickThrough, Mode=TwoWay}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,0"
                                       Text="{DynamicResource AutoHideCB}" />
                            <ui:ToggleSwitch Grid.Row="3" Grid.Column="1"
                                             Margin="0,10,0,0"
                                             HorizontalAlignment="Right"
                                             IsChecked="{Binding BoundWindow.IsAutoHide, Mode=TwoWay}" />

                            <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,10,0,0">
                                <TextBlock Text="Auto Hide Timeout" />
                                <TextBlock Style="{DynamicResource CaptionTextStyle}" Text="Timeout in seconds." />
                            </StackPanel>
                            <ui:NumberBox Grid.Row="4" Grid.Column="1"
                                          Margin="0,10,0,0"
                                          HorizontalAlignment="Right"
                                          Value="{Binding BoundWindow.AutoHideTimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Width="120"
                                          Minimum="1"
                                          Maximum="36000"
                                          IsEnabled="{Binding BoundWindow.IsAutoHide}"
                                          ClearButtonEnabled="False" />
                        </Grid>
                    </ui:Card>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Top">
                    <ui:Card Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <ui:SymbolIcon Symbol="Color24" FontSize="16"
                                               Margin="0,0,8,0" VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.Accent}" />
                                <TextBlock Style="{DynamicResource SectionSubtitleStyle}"
                                           Margin="0"
                                           Text="{DynamicResource WindowSurfaceLabel}"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <Label Style="{DynamicResource BaseLabelStyle}" Content="{DynamicResource BackgroundColor}" />
                            <ctrl:ColorSwatchPicker SwatchWidth="160"
                                                    SwatchHeight="32"
                                                    HorizontalAlignment="Left"
                                                    SelectedColor="{Binding BoundWindow.BackGroundColor, Mode=TwoWay}"
                                                    Margin="0,0,0,12" />

                            <Label Style="{DynamicResource BaseLabelStyle}"
                                   Content="{DynamicResource WindowCornerRadiusLabel}" />
                            <ui:NumberBox
                                Value="{Binding BoundWindow.WindowCornerRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Minimum="0" Maximum="64"
                                ClearButtonEnabled="False"
                                Margin="0,0,0,12" />

                            <Label Style="{DynamicResource BaseLabelStyle}"
                                   Content="{DynamicResource ContentPaddingLabel}" />
                            <ui:NumberBox
                                Value="{Binding BoundWindow.ContentPadding, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Minimum="0" Maximum="64"
                                ClearButtonEnabled="False" />
                        </StackPanel>
                    </ui:Card>

                    <ui:Card Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <ui:SymbolIcon Symbol="TextBulletListSquare24" FontSize="16"
                                               Margin="0,0,8,0" VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.Accent}" />
                                <TextBlock Style="{DynamicResource SectionSubtitleStyle}"
                                           Margin="0"
                                           Text="{DynamicResource MessagesInContainerLabel}"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <ui:ToggleSwitch IsChecked="{Binding BoundWindow.MessagesInContainer, Mode=TwoWay}"
                                             Content="{DynamicResource MessagesInContainerLabel}"
                                             Margin="0,0,0,12" />

                            <Label Style="{DynamicResource BaseLabelStyle}"
                                   Content="{DynamicResource MessageContainerPaddingLabel}" />
                            <ui:NumberBox
                                Value="{Binding BoundWindow.MessageContainerPadding, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Minimum="0" Maximum="64"
                                ClearButtonEnabled="False"
                                Margin="0,0,0,12" />

                            <Label Style="{DynamicResource BaseLabelStyle}"
                                   Content="{DynamicResource MessageContainerAlphaLabel}" />
                            <ui:NumberBox
                                Value="{Binding BoundWindow.MessageContainerAlpha, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Minimum="0" Maximum="255"
                                ClearButtonEnabled="False"
                                Margin="0,0,0,12" />

                            <Label Style="{DynamicResource BaseLabelStyle}"
                                   Content="{DynamicResource MessageContainerBorderThicknessLabel}" />
                            <ui:NumberBox
                                Value="{Binding BoundWindow.MessageContainerBorderThickness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Minimum="0" Maximum="12"
                                ClearButtonEnabled="False"
                                Margin="0,0,0,12" />

                            <Label Style="{DynamicResource BaseLabelStyle}"
                                   Content="{DynamicResource MessageContainerBorderAlphaLabel}" />
                            <ui:NumberBox
                                Value="{Binding BoundWindow.MessageContainerBorderAlpha, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Minimum="0" Maximum="255"
                                ClearButtonEnabled="False"
                                Margin="0,0,0,12" />

                            <ui:ToggleSwitch IsChecked="{Binding BoundWindow.ShowOnlyLastMessage, Mode=TwoWay}"
                                             Content="{DynamicResource ShowOnlyLastMessageLabel}" />
                        </StackPanel>
                    </ui:Card>

                    <ui:Card Padding="16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <ui:SymbolIcon Symbol="TextParagraphDirectionLeft20" FontSize="16"
                                               Margin="0,0,8,0" VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.Accent}" />
                                <TextBlock Style="{DynamicResource SectionSubtitleStyle}"
                                           Margin="0"
                                           Text="{DynamicResource ParagraphSettings}"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <Label Style="{DynamicResource BaseLabelStyle}" Content="{DynamicResource IntervalWidth}" />
                            <ui:NumberBox
                                Value="{Binding BoundWindow.SpacingCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Minimum="0" Maximum="100"
                                ClearButtonEnabled="False"
                                Margin="0,0,0,12" />

                            <Label Style="{DynamicResource BaseLabelStyle}" Content="{DynamicResource LineBreakHeight}" />
                            <ui:NumberBox
                                Value="{Binding BoundWindow.LineBreakHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Minimum="0" Maximum="100"
                                ClearButtonEnabled="False" />
                        </StackPanel>
                    </ui:Card>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>