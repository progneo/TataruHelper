<UserControl x:Class="FFXIVTataruHelper.Views.Pages.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource Brush.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="About"
                       Style="{DynamicResource BaseTextBlockStyle}"
                       FontSize="{DynamicResource FontSize.Subtitle}"
                       FontWeight="SemiBold" />
            <TextBlock Text="Project links and support channels."
                       Style="{DynamicResource BaseTextBlockStyle}"
                       Foreground="{DynamicResource Brush.TextSecondary}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{DynamicResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Style="{DynamicResource BaseTextBlockStyle}" Margin="0,0,0,10">
                    This build focuses on modern UX, stable overlays and translation reliability.
                </TextBlock>

                <TextBlock Style="{DynamicResource BaseTextBlockStyle}" Margin="0,0,0,8">
                    Fork repository:
                    <Hyperlink NavigateUri="https://github.com/progneo/TataruHelper"
                               RequestNavigate="Hyperlink_RequestNavigate">
                        https://github.com/progneo/TataruHelper
                    </Hyperlink>
                </TextBlock>

                <TextBlock Style="{DynamicResource BaseTextBlockStyle}" Margin="0,0,0,8">
                    Original repository:
                    <Hyperlink NavigateUri="https://github.com/NightlyRevenger/TataruHelper"
                               RequestNavigate="Hyperlink_RequestNavigate">
                        https://github.com/NightlyRevenger/TataruHelper
                    </Hyperlink>
                </TextBlock>

                <TextBlock Style="{DynamicResource BaseTextBlockStyle}">
                    Community Discord:
                    <Hyperlink NavigateUri="https://discord.gg/bSrpbd9" RequestNavigate="Hyperlink_RequestNavigate">
                        https://discord.gg/bSrpbd9
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>