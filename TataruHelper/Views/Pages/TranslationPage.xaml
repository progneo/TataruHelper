<UserControl x:Class="FFXIVTataruHelper.Views.Pages.TranslationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:utils="clr-namespace:WpfXamlExtensions;assembly=WpfXamlExtensions"
             mc:Ignorable="d">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{DynamicResource SectionTranslation}"
                       Style="{DynamicResource BaseTextBlockStyle}"
                       FontSize="{DynamicResource FontSize.Subtitle}"
                       FontWeight="SemiBold" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{DynamicResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{DynamicResource ChatCodeFiltersLabel}" FontWeight="SemiBold"
                               Margin="0,0,0,8" />

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding BoundWindow.ChatCodes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,4">
                                        <xctk:ColorPicker Style="{DynamicResource BaseColorPickerStyle}" Width="22"
                                                          Height="22"
                                                          ShowDropDownButton="False"
                                                          ShowTabHeaders="False"
                                                          Margin="8,0,0,0"
                                                          HorizontalAlignment="Right"
                                                          DockPanel.Dock="Right"
                                                          SelectedColor="{Binding Color}" />
                                        <CheckBox Style="{DynamicResource BaseCheckBoxStyle}"
                                                  Margin="0"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                  Content="{utils:ResourceBinding Name}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{DynamicResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource EngineRoutingLabel}" FontWeight="SemiBold" Margin="0,0,0,8" />

                    <Label Style="{DynamicResource BaseLabelStyle}" Content="{DynamicResource TranslationEngine}" />
                    <ComboBox Style="{DynamicResource BaseComboBoxStyle}"
                              ItemsSource="{Binding BoundWindow.TranslationEngines}"
                              DisplayMemberPath="Name"
                              IsSynchronizedWithCurrentItem="True" />

                    <Label Style="{DynamicResource BaseLabelStyle}" Content="{DynamicResource FFLanguage}" />
                    <ComboBox Style="{DynamicResource BaseComboBoxStyle}"
                              ItemsSource="{Binding BoundWindow.TranslateFromLanguagues}"
                              DisplayMemberPath="ShownName"
                              IsSynchronizedWithCurrentItem="True" />

                    <Label Style="{DynamicResource BaseLabelStyle}" Content="{DynamicResource TraslateTo}" />
                    <ComboBox Style="{DynamicResource BaseComboBoxStyle}"
                              ItemsSource="{Binding BoundWindow.TranslateToLanguagues}"
                              DisplayMemberPath="ShownName"
                              IsSynchronizedWithCurrentItem="True" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>