<UserControl x:Class="FFXIVTataruHelper.Views.Pages.GeneralPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource Brush.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="General"
                       Style="{DynamicResource BaseTextBlockStyle}"
                       FontSize="{DynamicResource FontSize.Subtitle}"
                       FontWeight="SemiBold" />
            <TextBlock Text="Global behavior that is shared across all chat windows."
                       Style="{DynamicResource BaseTextBlockStyle}"
                       Foreground="{DynamicResource Brush.TextSecondary}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{DynamicResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="Application flags" FontWeight="SemiBold" Margin="0,0,0,8" />
                <CheckBox Style="{DynamicResource BaseCheckBoxStyle}"
                          Content="{DynamicResource DirectMemoryCB}"
                          IsChecked="{Binding Shell.IsDirectMemoryReading, Mode=TwoWay}" />
                <CheckBox Style="{DynamicResource BaseCheckBoxStyle}"
                          Content="{DynamicResource HideToTrayCB}"
                          IsChecked="{Binding Shell.IsHideSettingsToTray, Mode=TwoWay}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>