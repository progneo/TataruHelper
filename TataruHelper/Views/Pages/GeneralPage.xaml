<UserControl x:Class="FFXIVTataruHelper.Views.Pages.GeneralPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource Brush.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Runtime behavior"
                   Style="{DynamicResource BaseTextBlockStyle}"
                   FontSize="{DynamicResource FontSize.Subtitle}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <GroupBox Grid.Row="1"
                  Style="{DynamicResource CardGroupBoxStyle}"
                  Header="General">
            <StackPanel>
                <CheckBox Content="{DynamicResource DirectMemoryCB}"
                          IsChecked="{Binding IsDirectMemoryReading, Mode=TwoWay}" />
                <CheckBox Content="{DynamicResource HideToTrayCB}"
                          IsChecked="{Binding IsHideSettingsToTray, Mode=TwoWay}" />
            </StackPanel>
        </GroupBox>
    </Grid>
</UserControl>