<UserControl x:Class="FFXIVTataruHelper.Views.Pages.HotkeysPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:draw="clr-namespace:System.Drawing;assembly=System.Drawing"
             xmlns:utils="clr-namespace:WpfXamlExtensions;assembly=WpfXamlExtensions"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             mc:Ignorable="d">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{DynamicResource ChatWindowHotkeys}"
                       Style="{DynamicResource BaseTextBlockStyle}"
                       FontSize="{DynamicResource FontSize.Subtitle}"
                       FontWeight="SemiBold" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{DynamicResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource ShortcutCaptureLabel}" FontWeight="SemiBold" Margin="0,0,0,8" />

                    <Label Style="{DynamicResource BaseLabelStyle}" Content="{DynamicResource ShowHideChatWindowHK}" />
                    <DockPanel Margin="0,0,0,8">
                        <Image Height="18" Width="18"
                               Source="{Binding Source={x:Static draw:SystemIcons.Question}, Converter={utils:IconToImageSourceConverter}, Mode=OneWay}"
                               Margin="6,0,0,0"
                               DockPanel.Dock="Right">
                            <Image.ToolTip>
                                <DynamicResource ResourceKey="ShowHideChatWindowHKToolTip" />
                            </Image.ToolTip>
                        </Image>
                        <TextBox Style="{DynamicResource BaseTextBoxStyle}"
                                 Margin="0"
                                 Text="{Binding BoundWindow.ShowHideChatKeysName, Mode=OneWay}"
                                 IsReadOnly="True"
                                 IsUndoEnabled="False"
                                 KeyDown="ShowHideChatWinHotKey_KeyDown"
                                 KeyUp="ShowHideChatWinHotKey_KeyUp" />
                    </DockPanel>

                    <Label Style="{DynamicResource BaseLabelStyle}" Content="{DynamicResource ClickThroughHK}" />
                    <DockPanel Margin="0,0,0,8">
                        <Image Height="18" Width="18"
                               Source="{Binding Source={x:Static draw:SystemIcons.Question}, Converter={utils:IconToImageSourceConverter}, Mode=OneWay}"
                               Margin="6,0,0,0"
                               DockPanel.Dock="Right">
                            <Image.ToolTip>
                                <DynamicResource ResourceKey="ClickThroughHKToolTip" />
                            </Image.ToolTip>
                        </Image>
                        <TextBox Style="{DynamicResource BaseTextBoxStyle}"
                                 Margin="0"
                                 Text="{Binding BoundWindow.ClickThoughtChatKeysName, Mode=OneWay}"
                                 IsReadOnly="True"
                                 IsUndoEnabled="False"
                                 KeyDown="ClickThroughHotKey_KeyDown"
                                 KeyUp="ClickThroughHotKey_KeyUp" />
                    </DockPanel>

                    <Label Style="{DynamicResource BaseLabelStyle}" Content="{DynamicResource ClearChatHK}" />
                    <DockPanel>
                        <Image Height="18" Width="18"
                               Source="{Binding Source={x:Static draw:SystemIcons.Question}, Converter={utils:IconToImageSourceConverter}, Mode=OneWay}"
                               Margin="6,0,0,0"
                               DockPanel.Dock="Right">
                            <Image.ToolTip>
                                <DynamicResource ResourceKey="ClearChatHKToolTip" />
                            </Image.ToolTip>
                        </Image>
                        <TextBox Style="{DynamicResource BaseTextBoxStyle}"
                                 Margin="0"
                                 Text="{Binding BoundWindow.ClearChatKeysName, Mode=OneWay}"
                                 IsReadOnly="True"
                                 IsUndoEnabled="False"
                                 KeyDown="ClearChatHotKey_KeyDown"
                                 KeyUp="ClearChatHotKey_KeyUp" />
                    </DockPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{DynamicResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource OverlayBehaviorLabel}" FontWeight="SemiBold" Margin="0,0,0,8" />

                    <CheckBox Style="{DynamicResource BaseCheckBoxStyle}"
                              IsChecked="{Binding BoundWindow.IsAlwaysOnTop, Mode=TwoWay}"
                              Content="{DynamicResource AlwaysOnTopCB}" />
                    <CheckBox Style="{DynamicResource BaseCheckBoxStyle}"
                              IsChecked="{Binding BoundWindow.IsClickThrough, Mode=TwoWay}"
                              Content="{DynamicResource ClickThroughCB}" />

                    <DockPanel>
                        <CheckBox Style="{DynamicResource BaseCheckBoxStyle}"
                                  Margin="0"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding BoundWindow.IsAutoHide, Mode=TwoWay}"
                                  Content="{DynamicResource AutoHideCB}" />
                        <xctk:IntegerUpDown Style="{DynamicResource BaseNumericUpDownStyle}"
                                            Value="{Binding BoundWindow.AutoHideTimeoutSeconds, Mode=TwoWay}"
                                            Width="120"
                                            Margin="12,0,0,0"
                                            Minimum="1"
                                            Maximum="36000" />
                    </DockPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>