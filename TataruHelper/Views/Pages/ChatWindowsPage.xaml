<UserControl x:Class="FFXIVTataruHelper.Views.Pages.ChatWindowsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{DynamicResource ChatWindowsTab}"
                       Style="{DynamicResource BaseTextBlockStyle}"
                       FontSize="{DynamicResource FontSize.Subtitle}"
                       FontWeight="SemiBold" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{DynamicResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{DynamicResource WindowListLabel}" FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <ListBox Grid.Row="1"
                             Style="{DynamicResource SidebarSectionListStyle}"
                             ItemContainerStyle="{DynamicResource SidebarSectionItemStyle}"
                             ItemsSource="{Binding Shell.SettingsViewModel.ChatWindows}"
                             SelectedIndex="{Binding Shell.SettingsViewModel.SelectedTabIndex, Mode=TwoWay}"
                             DisplayMemberPath="Name" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{DynamicResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{DynamicResource WindowDetailsLabel}" FontWeight="SemiBold" />

                    <StackPanel Grid.Row="1" Margin="0,10,0,10">
                        <Label Style="{DynamicResource BaseLabelStyle}" Content="{DynamicResource WindowNameLabel}" />
                        <TextBox Style="{DynamicResource BaseTextBoxStyle}"
                                 Width="260"
                                 Text="{Binding BoundWindow.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <UniformGrid Grid.Row="2" Columns="2" Margin="0,0,0,8">
                        <Button Style="{DynamicResource BaseButtonStyle}" Content="{DynamicResource AddButtonText}"
                                Command="{Binding Shell.AddWindowCommand}" />
                        <Button Style="{DynamicResource BaseButtonStyle}" Content="{DynamicResource DeleteButtonText}"
                                Command="{Binding Shell.DeleteWindowCommand}" />
                        <Button Style="{DynamicResource BaseButtonStyle}"
                                Content="{DynamicResource ShowHideButtonText}"
                                Command="{Binding Shell.ShowHideWindowCommand}" />
                        <Button Style="{DynamicResource BaseButtonStyle}" Content="{DynamicResource ResetButtonText}"
                                Command="{Binding Shell.ResetPositionCommand}" />
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>