<UserControl x:Class="FFXIVTataruHelper.Views.Pages.ChatWindowsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Style="{DynamicResource SectionTitleStyle}"
                   Text="{DynamicResource ChatWindowsTab}" />

        <TextBlock Grid.Row="1"
                   Style="{DynamicResource CaptionTextStyle}"
                   Margin="0,0,0,16"
                   Text="{DynamicResource ChatWindowsPageDescription}" />

        <!-- Toolbar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <ui:Button Appearance="Primary"
                       Icon="{ui:SymbolIcon Symbol=Add24}"
                       Content="{DynamicResource AddButtonText}"
                       Command="{Binding Shell.AddWindowCommand}"
                       Margin="0,0,8,0" />
            <ui:Button Appearance="Secondary"
                       Icon="{ui:SymbolIcon Symbol=Delete24}"
                       Content="{DynamicResource DeleteButtonText}"
                       Command="{Binding Shell.DeleteWindowCommand}"
                       Margin="0,0,8,0" />
            <ui:Button Appearance="Secondary"
                       Icon="{ui:SymbolIcon Symbol=Eye24}"
                       Content="{DynamicResource ShowHideButtonText}"
                       Command="{Binding Shell.ShowHideWindowCommand}"
                       Margin="0,0,8,0" />
            <ui:Button Appearance="Secondary"
                       Icon="{ui:SymbolIcon Symbol=ArrowReset24}"
                       Content="{DynamicResource ResetButtonText}"
                       Command="{Binding Shell.ResetPositionCommand}" />
        </StackPanel>

        <!-- Tabbed editor -->
        <TabControl Grid.Row="3"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0,6,0,0"
                    ItemsSource="{Binding Shell.SettingsViewModel.ChatWindows}"
                    SelectedIndex="{Binding Shell.SettingsViewModel.SelectedTabIndex, Mode=TwoWay}">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Chat24" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource Brush.SurfaceSubtle}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,8,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Style="{DynamicResource SectionSubtitleStyle}"
                                       Text="{DynamicResource WindowDetailsLabel}" />

                            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                <Label Style="{DynamicResource BaseLabelStyle}"
                                       Content="{DynamicResource WindowNameLabel}" />
                                <ui:TextBox Width="320"
                                            HorizontalAlignment="Left"
                                            Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Style="{DynamicResource CaptionTextStyle}"
                                       Text="{DynamicResource ChatWindowsTabHint}"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </Grid>
</UserControl>