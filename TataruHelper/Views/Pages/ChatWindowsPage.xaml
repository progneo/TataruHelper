<UserControl x:Class="FFXIVTataruHelper.Views.Pages.ChatWindowsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Style="{DynamicResource SectionTitleStyle}"
                           Text="{DynamicResource ChatWindowsTab}" />
                <TextBlock Style="{DynamicResource CaptionTextStyle}"
                           Text="{DynamicResource ChatWindowsPageDescription}" />
            </StackPanel>
            <ui:Button Grid.Column="1"
                       VerticalAlignment="Center"
                       Appearance="Primary"
                       Icon="{ui:SymbolIcon Symbol=Add24}"
                       Content="{DynamicResource AddButtonText}"
                       Command="{Binding Shell.AddWindowCommand}" />
        </Grid>

        <ListBox Grid.Row="1"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="0"
                 Margin="0,0,0,12"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                 ItemsSource="{Binding Shell.SettingsViewModel.ChatWindows}"
                 SelectedValuePath="WinId"
                 SelectedValue="{Binding Shell.SelectedChatWindowId, Mode=TwoWay}">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource TabPillItemStyle}" />
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Chat24"
                                       FontSize="14"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="2"
                Style="{DynamicResource CardBorderStyle}"
                Padding="16"
                VerticalAlignment="Top"
                DataContext="{Binding BoundWindow}">
            <StackPanel>
                <TextBlock Style="{DynamicResource SectionSubtitleStyle}"
                           Text="{DynamicResource WindowDetailsLabel}"
                           Margin="0,0,0,12" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="{Binding Name, Mode=TwoWay}"
                                PlaceholderText="{DynamicResource WindowNameLabel}" />
                    <ui:Button Grid.Column="1"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Appearance="Secondary"
                               Icon="{ui:SymbolIcon Symbol=Delete24}"
                               Content="{DynamicResource DeleteButtonText}"
                               Command="{Binding DataContext.Shell.DeleteWindowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <ui:Button Grid.Column="2"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Appearance="Secondary"
                               Icon="{ui:SymbolIcon Symbol=Eye24}"
                               Content="{DynamicResource ShowHideButtonText}"
                               Command="{Binding DataContext.Shell.ShowHideWindowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <ui:Button Grid.Column="3"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Appearance="Secondary"
                               Icon="{ui:SymbolIcon Symbol=ArrowReset24}"
                               Content="{DynamicResource ResetButtonText}"
                               Command="{Binding DataContext.Shell.ResetPositionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>