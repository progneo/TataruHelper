<UserControl x:Class="FFXIVTataruHelper.Views.Pages.ChatWindowsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource Brush.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Chat windows"
                       Style="{DynamicResource BaseTextBlockStyle}"
                       FontSize="{DynamicResource FontSize.Subtitle}"
                       FontWeight="SemiBold" />
            <TextBlock Text="Each window keeps independent behavior, translation and appearance settings."
                       Style="{DynamicResource BaseTextBlockStyle}"
                       Foreground="{DynamicResource Brush.TextSecondary}" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{DynamicResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Window list" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ListBox Grid.Row="1"
                             Style="{DynamicResource SidebarSectionListStyle}"
                             ItemContainerStyle="{DynamicResource SidebarSectionItemStyle}"
                             ItemsSource="{Binding Shell.SettingsViewModel.ChatWindows}"
                             SelectedIndex="{Binding Shell.SettingsViewModel.SelectedTabIndex, Mode=TwoWay}"
                             DisplayMemberPath="Name" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{DynamicResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Window details" FontWeight="SemiBold" />

                    <StackPanel Grid.Row="1" Margin="0,10,0,10">
                        <Label Style="{DynamicResource BaseLabelStyle}" Content="Window name" />
                        <TextBox Style="{DynamicResource BaseTextBoxStyle}"
                                 Width="260"
                                 Text="{Binding BoundWindow.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <WrapPanel Grid.Row="2" Margin="0,0,0,8">
                        <Button Style="{DynamicResource BaseButtonStyle}" Content="Add" Width="110"
                                Command="{Binding Shell.AddWindowCommand}" />
                        <Button Style="{DynamicResource BaseButtonStyle}" Content="Delete" Width="110"
                                Command="{Binding Shell.DeleteWindowCommand}" />
                        <Button Style="{DynamicResource BaseButtonStyle}" Content="Show/Hide" Width="120"
                                Command="{Binding Shell.ShowHideWindowCommand}" />
                        <Button Style="{DynamicResource BaseButtonStyle}" Content="Reset position" Width="130"
                                Command="{Binding Shell.ResetPositionCommand}" />
                    </WrapPanel>

                    <TextBlock Grid.Row="3"
                               Text="Use this page to create a focused layout per chat context (raid, party, linkshell, etc.)."
                               Foreground="{DynamicResource Brush.TextSecondary}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>