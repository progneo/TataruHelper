// Papago request encoder evaluated by Jurassic from PapagoEncoder.cs.
//
// EncodeTransaltionRequest(requestJson, hmacKey) -> JSON string with
//   { stringReqv, hmacKey, hmacInput, guid, guidTime }
//
// PapagoEncoder.cs reads those fields, computes
//   sign = base64(HMAC-MD5(hmacInput, hmacKey))
// and uses "PPG <guid>:<sign>" as the Authorization header.
//
// The HMAC key is no longer baked into this resource. It is scraped at
// runtime from the live papago.naver.com bundle by PapagoKeyResolver.cs
// and passed in as the second argument.

var papagoUrl = "https://papago.naver.com/apis/n2mt/translate";

var papagoRequestFields = [
    "deviceId", "locale", "dict", "dictDisplay",
    "honorific", "instant", "paging",
    "source", "target", "text"
];

function papagoUuidV4() {
    var d = new Date().getTime();
    return "xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx".replace(/[xy]/g, function (c) {
        var r = (d + Math.random() * 16) % 16 | 0;
        d = Math.floor(d / 16);
        return (c === "x" ? r : (r & 0x3) | 0x8).toString(16);
    });
}

function EncodeTransaltionRequest(requestJson, hmacKey) {
    var req = JSON.parse(requestJson);
    var guid = papagoUuidV4();
    var guidTime = new Date().getTime().toString();

    var parts = [];
    for (var i = 0; i < papagoRequestFields.length; i++) {
        var k = papagoRequestFields[i];
        if (req[k] === undefined || req[k] === null) {
            continue;
        }
        parts.push(k + "=" + encodeURIComponent(req[k]));
    }
    var stringReqv = parts.join("&");

    var hmacInput = guid + "\n" + papagoUrl + "\n" + guidTime;

    return JSON.stringify({
        guid: guid,
        guidTime: guidTime,
        hmacInput: hmacInput,
        hmacKey: hmacKey,
        stringReqv: stringReqv
    });
}
